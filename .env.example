# Application
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=contact@hytalehunt.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hytalehunt

# Redis (for rate limiting and sessions)
REDIS_URL=redis://localhost:6379

# Authentication
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Discord OAuth
NEXT_PUBLIC_DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Google Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_PREMIUM_PAYMENT_LINK=https://buy.stripe.com/...
NEXT_PUBLIC_PREMIUM_PLUS_PAYMENT_LINK=https://buy.stripe.com/...
NEXT_PUBLIC_PREMIUM_WEEKLY_BUNDLE_PAYMENT_LINK=https://buy.stripe.com/...
NEXT_PUBLIC_PREMIUM_MONTHLY_BUNDLE_PAYMENT_LINK=https://buy.stripe.com/...

# Cloudflare Turnstile (Anti-bot)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Discord Notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_LAUNCH_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Email (Resend)
RESEND_API_KEY=re_...

# Cron Jobs (Vercel)
CRON_SECRET=your_cron_secret

# UploadThing
NEXT_PUBLIC_UPLOADTHING_URL=your_uploadthing_url_without_protocol
UPLOADTHING_TOKEN=your_uploadthing_token

# Plausible Analytics
PLAUSIBLE_API_KEY=
PLAUSIBLE_URL=
PLAUSIBLE_SITE_ID=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_...
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://app.posthog.com