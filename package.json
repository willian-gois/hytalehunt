{
  "name": "hytalehunt",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev --turbopack",
    "lint": "bunx --bun biome check",
    "lint:fix": "bunx --bun biome check --write",
    "prepare": "npx simple-git-hooks",
    "start": "next start",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/auth/stripe/webhook",
    "update-launches": "bun ./scripts/update-launches.ts"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged --verbose",
    "commit-msg": "npx commitlint --edit $1"
  },
  "commitlint": {
    "extends": ["@commitlint/config-conventional"]
  },
  "lint-staged": {
    "package.json": "sort-package-json"
  },
